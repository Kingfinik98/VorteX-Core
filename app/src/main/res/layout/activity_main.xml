<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07090D"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZIXINE"
            android:textColor="#FF1744"
            android:textSize="50sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.2" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E N G I N E   C O R E"
            android:textColor="#00E5FF"
            android:textSize="12sp"
            android:letterSpacing="0.5"
            android:fontFamily="sans-serif-condensed" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_verified"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM VERIFIED"
            android:textColor="#00E5FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Close this app and use Quick Settings (Status Bar) to control Zixine Engine."
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingHorizontal="30dp"/>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_locked"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        app:cardBackgroundColor="#0D111A"
        app:cardCornerRadius="16dp"
        app:strokeColor="#FF1744"
        app:strokeWidth="1dp"
        android:elevation="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UNSUPPORTED KERNEL"
                android:textColor="#FF1744"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Zixine Kernel not detected."
                android:textColor="#66FFFFFF"
                android:textSize="12sp" />
            
            <EditText
                android:id="@+id/input_code"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:hint="Enter Passkey"
                android:textColorHint="#44FFFFFF"
                android:textColor="#FFFFFF"
                android:inputType="numberPassword"
                android:gravity="center"
                android:backgroundTint="#FF1744"
                android:textSize="18sp"
                android:letterSpacing="0.3"/>
                
            <Button
                android:id="@+id/btn_unlock"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="20dp"
                android:text="BYPASS SECURITY"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#FF1744"
                app:cornerRadius="8dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp"
        android:text="STRICTLY FOR ZIXINE USERS"
        android:textColor="#33FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:letterSpacing="0.2"/>

</RelativeLayout>        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        app:cardBackgroundColor="#12161F"
        app:cardCornerRadius="20dp"
        app:strokeColor="#FF1744"
        app:strokeWidth="1dp"
        android:visibility="gone"
        android:elevation="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SECURITY CHECK FAILED"
                android:textColor="#FF1744"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/input_code"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Pass: 445456"
                android:textColor="#FFFFFF"
                android:inputType="number"
                android:gravity="center"
                android:backgroundTint="#FF1744" />
            <Button
                android:id="@+id/btn_unlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="UNLOCK ZIXINE"
                android:backgroundTint="#FF1744" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/main_ui"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center">
        
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_perf"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="43dp"
            app:cardBackgroundColor="#12161F"
            app:strokeColor="#1E2433"
            app:strokeWidth="1dp">
            <TextView android:id="@+id/status_perf" android:layout_width="match_parent" android:layout_height="match_parent" android:text="OFF" android:textColor="#44FFFFFF" android:gravity="center" android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_gms"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="43dp"
            app:cardBackgroundColor="#12161F"
            app:strokeColor="#1E2433"
            app:strokeWidth="1dp">
            <TextView android:id="@+id/status_gms" android:layout_width="match_parent" android:layout_height="match_parent" android:text="OFF" android:textColor="#44FFFFFF" android:gravity="center" android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_extreme"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="43dp"
            app:cardBackgroundColor="#12161F"
            app:strokeColor="#1E2433"
            app:strokeWidth="1dp">
            <TextView android:id="@+id/status_extreme" android:layout_width="match_parent" android:layout_height="match_parent" android:text="OFF" android:textColor="#44FFFFFF" android:gravity="center" android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_trigger"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="60dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#1E2433">
        <TextView android:id="@+id/arrow_text" android:layout_width="match_parent" android:layout_height="match_parent" android:text="▲" android:textColor="#FFFFFF" android:gravity="center" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tutorial_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp"
        android:text="ZIXINE ENGINE | KERNEL EXCLUSIVE"
        android:textColor="#66FFFFFF"
        android:textSize="10sp"
        android:gravity="center"
        android:visibility="gone" />

</RelativeLayout>
