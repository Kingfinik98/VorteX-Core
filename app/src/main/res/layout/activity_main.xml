<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07090D"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ZIXINE"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENGINE CORE"
        android:textColor="#FF1744"
        android:textSize="12sp"
        android:letterSpacing="0.3" />

    <LinearLayout
        android:id="@+id/layout_locked"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        android:visibility="gone">
        <EditText
            android:id="@+id/input_code"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Passkey"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1744"
            android:inputType="numberPassword"
            android:gravity="center" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_unlock"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:text="UNLOCK"
            android:background="#FF1744"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_verified"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="30dp"
        android:visibility="visible">

        <TextView android:text="RAM USAGE" android:textColor="#88FFFFFF" android:textSize="10sp" />
        <TextView android:id="@+id/tv_ram" android:text="..." android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="10dp" />

        <TextView android:text="ZRAM SIZE" android:textColor="#88FFFFFF" android:textSize="10sp" />
        <TextView android:id="@+id/tv_zram" android:text="..." android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="10dp" />

        <TextView android:text="CPU GOVERNOR" android:textColor="#88FFFFFF" android:textSize="10sp" />
        <TextView android:id="@+id/tv_cpu" android:text="..." android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="10dp" />

        <TextView android:text="BATTERY" android:textColor="#88FFFFFF" android:textSize="10sp" />
        <TextView android:id="@+id/tv_battery" android:text="..." android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="20dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_cpu_gov"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="SET CPU GOVERNOR"
            android:background="#00E5FF"
            android:textColor="#000000"
            android:layout_marginBottom="10dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_clean_ram"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="BRUTAL RAM CLEANER"
            android:background="#FF1744"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</LinearLayout>
