<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000814" android:orientation="vertical" android:padding="20dp">
    
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="NARUKAMI ENGINE V23" android:textColor="#00d4ff" android:textSize="20sp" android:textStyle="bold" android:layout_gravity="center" />

    <Button android:id="@+id/btn_gms" android:layout_width="match_parent" android:layout_height="80dp" android:layout_marginTop="30dp" android:text="GMS KILLER" android:textStyle="bold" />
    <Button android:id="@+id/btn_extreme" android:layout_width="match_parent" android:layout_height="80dp" android:layout_marginTop="15dp" android:text="EXTREME SEAL" android:textStyle="bold" />
    <Button android:id="@+id/btn_perf" android:layout_width="match_parent" android:layout_height="80dp" android:layout_marginTop="15dp" android:text="PERFORMANCE BOOST" android:textStyle="bold" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Manual Game List &amp; Optimization Active" android:textColor="#44ffffff" android:gravity="center" android:layout_marginTop="20dp" android:textSize="10sp" />
</LinearLayout>
